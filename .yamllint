extends: default

ignore-from-file: [.gitignore, .yamlignore]

rules:
  document-start: disable
  octal-values: enable
  truthy:
    allowed-values: ['true', 'false', 'on']
  line-length:
    max: 240
  indentation:
    check-multi-line-strings: false
    indent-sequences: consistent
  brackets:
    max-spaces-inside: 1
    max-spaces-inside-empty: 0
  braces:
    max-spaces-inside: 1
    max-spaces-inside-empty: 0
